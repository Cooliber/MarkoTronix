{
  "name": "markotronix-hvac-crm",
  "version": "1.0.0",
  "description": "HVAC CRM System with n8n integration",
  "private": true,
  "workspaces": [
    "hvac-ui"
  ],
  "scripts": {
    "dev": "cd hvac-ui && npm run dev",
    "build": "cd hvac-ui && npm run build",
    "start": "cd hvac-ui && npm start",
    "lint": "cd hvac-ui && npm run lint",
    "test": "cd hvac-ui && npm test",
    "docker:build": "docker build -t hvac-crm-ui .",
    "docker:run": "docker run -p 3000:3000 --env-file hvac-ui/.env.production hvac-crm-ui",
    "docker:compose": "docker-compose up -d",
    "docker:compose:down": "docker-compose down",
    "deploy:nixpacks": "nixpacks build . --name hvac-crm",
    "deploy:sevilla": "cd hvac-ui && ./deploy/deploy-to-sevilla.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cooliber/MarkoTronix.git"
  },
  "keywords": [
    "hvac",
    "crm",
    "n8n",
    "workflow",
    "automation"
  ],
  "author": "MarkoTronix",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/Cooliber/MarkoTronix/issues"
  },
  "homepage": "https://github.com/Cooliber/MarkoTronix#readme",
  "engines": {
    "node": ">=18.0.0"
  }
}