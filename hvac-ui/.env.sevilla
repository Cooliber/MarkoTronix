# Sevilla Environment Configuration

# API Configuration
NEXT_PUBLIC_API_URL=https://api.hvac-crm.sevilla.app/api
NEXT_PUBLIC_WEBSOCKET_URL=wss://api.hvac-crm.sevilla.app/ws
API_URL=https://api.hvac-crm.sevilla.app/api

# Authentication
NEXT_PUBLIC_JWT_SECRET=sevilla_jwt_secret_replace_in_production
NEXT_PUBLIC_AUTH_COOKIE_NAME=hvac_auth_token
JWT_SECRET=sevilla_jwt_secret_replace_in_production
AUTH_COOKIE_NAME=hvac_auth_token

# Map API Keys
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here

# Feature Flags
NEXT_PUBLIC_ENABLE_TELEGRAM_BOT=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
ENABLE_ANALYTICS=true
ENABLE_NOTIFICATIONS=true

# Application Environment
APP_ENV=production
NEXT_PUBLIC_APP_ENV=production

# Deployment
NEXT_PUBLIC_SITE_URL=https://hvac-crm.sevilla.app
PORT=3000
HOST=0.0.0.0

# Internationalization
NEXT_PUBLIC_DEFAULT_LOCALE=pl

# n8n Integration
NEXT_PUBLIC_N8N_URL=https://n8n.hvac-crm.sevilla.app
NEXT_PUBLIC_N8N_API_KEY=sevilla_n8n_api_key_replace_in_production
N8N_URL=https://n8n.hvac-crm.sevilla.app
N8N_API_KEY=sevilla_n8n_api_key_replace_in_production
N8N_WEBHOOK_SECRET=sevilla_webhook_secret_replace_in_production
NEXT_PUBLIC_ENABLE_N8N_INTEGRATION=true

# Sevilla Specific
SEVILLA_APP_NAME=hvac-crm
SEVILLA_REGION=eu-central-1
CUSTOM_DOMAINS=hvac-crm.example.com,crm.example.com