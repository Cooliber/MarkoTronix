# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_WEBSOCKET_URL=ws://localhost:8000/ws
API_URL=http://localhost:8000/api

# Authentication
NEXT_PUBLIC_JWT_SECRET=your_jwt_secret_here
NEXT_PUBLIC_AUTH_COOKIE_NAME=hvac_auth_token
JWT_SECRET=your_jwt_secret_here
AUTH_COOKIE_NAME=hvac_auth_token

# Map API Keys
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here

# Feature Flags
NEXT_PUBLIC_ENABLE_TELEGRAM_BOT=false
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
ENABLE_ANALYTICS=false
ENABLE_NOTIFICATIONS=true

# Application Environment
APP_ENV=development
NEXT_PUBLIC_APP_ENV=development

# Deployment
NEXT_PUBLIC_SITE_URL=http://localhost:3000
PORT=3000
HOST=0.0.0.0

# Internationalization
NEXT_PUBLIC_DEFAULT_LOCALE=en

# n8n Integration
NEXT_PUBLIC_N8N_URL=http://localhost:5678
NEXT_PUBLIC_N8N_API_KEY=your_n8n_api_key_here
N8N_URL=http://localhost:5678
N8N_API_KEY=your_n8n_api_key_here
N8N_WEBHOOK_SECRET=your_webhook_secret_here
NEXT_PUBLIC_ENABLE_N8N_INTEGRATION=true