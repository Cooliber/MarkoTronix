{
  "name": "hvac-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:prod": "tsc && next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "export": "next export",
    "build:standalone": "next build && next export",
    "build:docker": "docker build -t hvac-ui .",
    "analyze": "ANALYZE=true next build",
    "test": "jest",
    "test:watch": "jest --watch",
    "deploy:sevilla": "./deploy/deploy-to-sevilla.sh",
    "deploy:nixpacks": "./deploy/deploy-with-nixpacks.sh",
    "docker:build": "docker build -t hvac-crm-ui .",
    "docker:run": "docker run -p 3000:3000 --env-file .env.production hvac-crm-ui",
    "docker:compose": "docker-compose -f ./deploy/docker-compose.yml up -d",
    "docker:compose:down": "docker-compose -f ./deploy/docker-compose.yml down",
    "mock-api": "cd mock-api && npm start",
    "build:sevilla": "cp .env.sevilla .env.production && next build",
    "start:sevilla": "NODE_ENV=production next start"
  },
  "dependencies": {
    "@chakra-ui/icons": "^2.2.4",
    "@chakra-ui/react": "^2.8.2",
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.0",
    "@gsap/react": "^2.1.0",
    "axios": "^1.6.7",
    "chart.js": "^4.4.2",
    "date-fns": "^3.3.1",
    "framer-motion": "^11.0.8",
    "gsap": "^3.13.0",
    "i18next": "^23.10.1",
    "jwt-decode": "^4.0.0",
    "leaflet": "^1.9.4",
    "next": "^14.2.28",
    "next-i18next": "^15.4.2",
    "next-pwa": "^5.6.0",
    "react": "18.2.0",
    "react-beautiful-dnd": "^13.1.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.51.0",
    "react-i18next": "^14.1.0",
    "react-icons": "^5.0.1",
    "react-leaflet": "^4.2.1"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.8",
    "@types/node": "20.11.24",
    "@types/react": "18.2.61",
    "@types/react-beautiful-dnd": "^13.1.8",
    "@types/react-dom": "18.2.19",
    "eslint": "8.57.0",
    "eslint-config-next": "14.1.3",
    "typescript": "5.3.3"
  }
}
