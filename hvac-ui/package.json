{
  "name": "hvac-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "export": "next export",
    "build:standalone": "next build && next export",
    "build:docker": "docker build -t hvac-ui .",
    "analyze": "ANALYZE=true next build",
    "test": "jest",
    "test:watch": "jest --watch",
    "prepare": "husky install",
    "deploy:sevilla": "./deploy/deploy-to-sevilla.sh",
    "deploy:nixpacks": "./deploy/deploy-with-nixpacks.sh",
    "docker:build": "docker build -t hvac-crm-ui .",
    "docker:run": "docker run -p 3000:3000 --env-file .env.production hvac-crm-ui",
    "docker:compose": "docker-compose -f ./deploy/docker-compose.yml up -d",
    "docker:compose:down": "docker-compose -f ./deploy/docker-compose.yml down",
    "mock-api": "cd mock-api && npm start",
    "build:sevilla": "cp .env.sevilla .env.production && next build",
    "start:sevilla": "NODE_ENV=production next start"
  },
  "dependencies": {
    "@chakra-ui/react": "^2.8.0",
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "axios": "^1.4.0",
    "chart.js": "^4.3.3",
    "date-fns": "^2.30.0",
    "framer-motion": "^10.15.0",
    "gsap": "^3.13.0",
    "i18next": "^25.0.2",
    "jwt-decode": "^3.1.2",
    "leaflet": "^1.9.4",
    "n8n-client": "^0.4.0",
    "next": "13.4.12",
    "next-i18next": "^15.4.2",
    "next-pwa": "^5.6.0",
    "react": "18.2.0",
    "react-beautiful-dnd": "^13.1.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.45.2",
    "react-i18next": "^15.5.1",
    "react-icons": "^4.10.1",
    "react-leaflet": "^4.2.1"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.3",
    "@types/node": "20.4.5",
    "@types/react": "18.2.18",
    "@types/react-beautiful-dnd": "^13.1.4",
    "@types/react-dom": "18.2.7",
    "eslint": "8.46.0",
    "eslint-config-next": "13.4.12",
    "typescript": "5.1.6"
  }
}
