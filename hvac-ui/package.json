{
  "name": "hvac-ui",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:prod": "tsc && next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "export": "next export",
    "build:standalone": "next build && next export",
    "build:docker": "docker build -t hvac-ui .",
    "analyze": "cross-env ANALYZE=true next build",
    "test": "jest",
    "test:watch": "jest --watch",
    "deploy:sevilla": "node ./deploy/deploy-to-sevilla.js",
    "deploy:nixpacks": "node ./deploy/deploy-with-nixpacks.js",
    "docker:build": "docker build -t hvac-crm-ui .",
    "docker:run": "docker run -p 3000:3000 --env-file .env.production hvac-crm-ui",
    "docker:compose": "docker-compose -f ./deploy/docker-compose.yml up -d",
    "docker:compose:down": "docker-compose -f ./deploy/docker-compose.yml down",
    "mock-api": "cd mock-api && npm start",
    "build:sevilla": "node -e \"require('fs').copyFileSync('.env.sevilla', '.env.production')\" && next build",
    "start:sevilla": "cross-env NODE_ENV=production next start",
    "generate-icons": "node scripts/generate-icons.js",
    "prepare-prod": "npm run generate-icons && npm run build:prod",
    "fix-install": "npm cache clean --force && npm install --no-fund --no-audit"
  },
  "dependencies": {
    "@chakra-ui/icons": "^2.2.4",
    "@chakra-ui/react": "^2.8.2",
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.0",
    "@gsap/react": "^2.1.0",
    "axios": "^1.6.7",
    "chart.js": "^4.4.2",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.9.4",
    "gsap": "^3.13.0",
    "i18next": "^25.0.2",
    "jwt-decode": "^4.0.0",
    "leaflet": "^1.9.4",
    "next": "^14.2.28",
    "next-i18next": "^15.4.2",
    "next-pwa": "^5.6.0",
    "react": "18.2.0",
    "react-beautiful-dnd": "^13.1.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.51.0",
    "react-i18next": "^15.5.1",
    "react-icons": "^5.0.1",
    "react-leaflet": "^4.2.1",
    "react-toastify": "^11.0.5"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^14.2.28",
    "@swc/core": "^1.11.24",
    "@swc/jest": "^0.2.38",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^29.5.14",
    "@types/leaflet": "^1.9.8",
    "@types/node": "^22.15.3",
    "@types/react": "^18.2.61",
    "@types/react-beautiful-dnd": "^13.1.8",
    "@types/react-dom": "^18.2.19",
    "canvas": "^2.11.2",
    "chalk": "^4.1.2",
    "cross-env": "^7.0.3",
    "eslint": "8.57.0",
    "eslint-config-next": "14.1.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "npm-check-updates": "^16.14.18",
    "typescript": "^5.8.3"
  }
}
