# FastAPI Configuration
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
SECRET_KEY=your_secret_key_here
ENVIRONMENT=development  # development, staging, production

# Database (Supabase)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
POSTGRES_PASSWORD=postgres
POSTGRES_USER=postgres
POSTGRES_DB=hvac_crm

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO (S3-compatible storage)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# OpenAI / OpenRouter
OPENAI_API_KEY=your_openai_api_key_here

# DocuSign
DOCUSIGN_CLIENT_ID=your_docusign_client_id_here
DOCUSIGN_SECRET=your_docusign_secret_here

# SMTP (Mailhog for dev)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@hvac-crm.com

# Qdrant
QDRANT_URL=http://qdrant:6333

# Flower (Celery monitoring)
FLOWER_BASIC_AUTH=admin:admin

# n8n (Workflow automation)
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin
N8N_ENCRYPTION_KEY=n8n-encryption-key
N8N_WEBHOOK_URL=http://localhost:5678/

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Twilio (for SMS)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Microservices URLs
MAIL_SERVICE_URL=http://mail-ingest:8000
OFFER_SERVICE_URL=http://offer-generation:8000
LINK_SERVICE_URL=http://link-service:8000